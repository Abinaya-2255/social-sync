# ─── Social Sync Environment Variables ───────────────────────────────────────
#
# Copy this file to .env and fill in your values.
#
# cp .env.example .env

# ── API ──────────────────────────────────────────────────────────────────────
# Set to 'false' to disable mock data and use the real backend API.
# Default: 'true' (mocks enabled — no backend required for development)
VITE_USE_MOCKS=true

# Base URL for the real backend REST API.
# Only used when VITE_USE_MOCKS=false
VITE_API_BASE_URL=http://localhost:3000/api
